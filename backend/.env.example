# Copy this file to .env and fill in the values before running the backend.
# Never commit .env to version control.

# Shared secret between the Gmail Add-on and this backend.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-strong-random-secret-here

# Anthropic API key for Claude content analysis.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: swap to claude-sonnet-4-6 for higher-quality analysis (costs more).
# MODEL=claude-haiku-4-5-20251001
